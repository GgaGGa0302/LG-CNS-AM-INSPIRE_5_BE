# 자동 감지된 텍스트 파일은 OS에 맞게 정규화
* text=auto

# Gradle wrapper 스크립트는 반드시 LF (Windows에서도 Git Bash로 실행되므로)
/gradlew text eol=lf
*.bat text eol=crlf

# 소스/설정 파일은 LF로 통일 (팀원 OS 상관없이 커밋 시 통일)
*.java text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.gradle text eol=lf

# 바이너리 파일은 diff/line-ending 처리 안 함
*.jar binary
*.png binary
*.jpg binary